# Скопируйте в .env и заполните реальными значениями. Не коммитьте .env в репозиторий.
# docker-compose env_file не поддерживает инлайн-комментарии после значения —
# комментарий всегда на отдельной строке.

# --- Окружение ---
ENVIRONMENT=dev
LOG_LEVEL=INFO

# --- База данных ---
DATABASE_URL=postgresql+asyncpg://nxai:nxai@postgres:5432/nxai

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LLM (рерайт) ---
ANTHROPIC_API_KEY=
# Эмбеддинги (Voyage AI) — используются дедупом (core/services/dedup.py),
# в отличие от NX подключены к пайплайну с самого начала, не опционально.
VOYAGE_API_KEY=

# --- Telethon (пул read-only сессий, читающих чужие source_channels) ---
# api_id/api_hash — https://my.telegram.org -> API development tools, общие для
# всего пула. Сами session string'и — по одной на TelethonSession в БД, не
# здесь (см. scripts/generate_telethon_session.py, ARCHITECTURE.md §7).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Наблюдаемость ---
SENTRY_DSN=

# --- Web API / панель ---
API_SECRET_KEY=
TELEGRAM_LOGIN_BOT_USERNAME=
# Вход по логину/паролю — первого (и любого следующего) админа заводит:
#   docker compose exec api python scripts/create_admin.py --username admin

# --- Admin-бот ---
# Токен агрегирующего бота (уведомления+статистика по всем темам) — можно
# задать здесь для первого запуска или сразу как ChannelBot(role=admin) в БД
# (панель управляет остальными, тематическими токенами — см. ARCHITECTURE.md §7).
ADMIN_BOT_TOKEN=

# --- Прод-деплой ---
# ENVIRONMENT=prod обязателен для docker-compose.prod.yml.
