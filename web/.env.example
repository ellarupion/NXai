# /api проксируется Vite-сервером на localhost:8000 (см. vite.config.ts) — тот же
# приём, что nginx использует в проде (deploy/nginx/nginx.conf). Оставляйте /api
# как есть даже при открытии панели через ngrok/другой домен — без прокси браузер
# уйдёт напрямую на localhost:8000 другого происхождения и упрётся в CORS.
VITE_API_URL=/api
